#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
JAVA_PID=""

cleanup() {
  status=$?
  trap - EXIT INT TERM

  if [[ -n "$JAVA_PID" ]] && kill -0 "$JAVA_PID" 2>/dev/null; then
    echo "Stopping backend (PID: $JAVA_PID)..."
    kill "$JAVA_PID" 2>/dev/null || true
    wait "$JAVA_PID" 2>/dev/null || true
  fi

  exit "$status"
}

trap cleanup EXIT INT TERM

cd "$ROOT_DIR"
"$SCRIPT_DIR/doctor"

if [[ ! -d node_modules ]]; then
  echo "Frontend dependencies are missing. Run: t/setup" >&2
  exit 1
fi

if command -v corepack >/dev/null 2>&1; then
  YARN=(corepack yarn)
else
  YARN=(yarn)
fi

echo "Starting Spring Boot on http://localhost:8000..."
(
  cd backend
  exec ./mvnw spring-boot:run
) &
JAVA_PID=$!

sleep 1
if ! kill -0 "$JAVA_PID" 2>/dev/null; then
  echo "The backend exited during startup. Review the output above." >&2
  wait "$JAVA_PID"
fi

echo "Backend process started; Maven may still be compiling."
echo "Starting Next.js on http://localhost:3000..."
"${YARN[@]}" dev
